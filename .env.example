# LegacyLens Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# --- API Keys (Required) ---
VOYAGE_API_KEY=your-voyage-api-key
OPENAI_API_KEY=your-openai-api-key
COHERE_API_KEY=your-cohere-api-key

# --- Qdrant Cloud (Required) ---
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# --- Model Configuration (Optional — defaults shown) ---
LEGACYLENS_EMBEDDING_MODEL=voyage-code-2
LEGACYLENS_LLM_MODEL=gpt-4o
LEGACYLENS_LLM_FALLBACK_MODEL=gpt-4o-mini

# --- Qdrant Collection (Optional) ---
LEGACYLENS_COLLECTION=legacylens

# --- API Server (Optional) ---
LEGACYLENS_API_HOST=0.0.0.0
LEGACYLENS_API_PORT=8000

# --- Deployed API URL (for CLI + frontend) ---
LEGACYLENS_API_URL=https://legacylens.onrender.com
